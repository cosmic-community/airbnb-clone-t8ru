# .env.example
# Cosmic API credentials
COSMIC_BUCKET_SLUG=your-bucket-slug
COSMIC_READ_KEY=your-read-key
COSMIC_WRITE_KEY=your-write-key

# Support Chat Agent
COSMIC_AGENT_TOKEN=your-agent-bearer-token
COSMIC_AGENT_ENDPOINT=https://your-agent-endpoint-url/v3/ai/agents/YOUR_AGENT_ID/messages?slug=YOUR_BUCKET_SLUG